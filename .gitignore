# Dependencies
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb

# Build outputs
dist/
dist-ssr/
build/
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS files
.DS_Store
Thumbs.db

# Cache
.cache/
.parcel-cache/
.next/
.nuxt/
.vite/

# Large image assets (keep source images, ignore built/dist versions)
/src/assets/**/*.jpg
/src/assets/**/*.jpeg
/src/assets/**/*.png
/src/assets/**/*.gif
/src/assets/**/*.webp
/src/assets/**/*.svg
!/src/assets/**/favicon.*
!/src/assets/**/icon.*
!/public/**/*

# Built assets in dist (already covered by dist/ but explicit for clarity)
/dist/assets/**/*.jpg
/dist/assets/**/*.jpeg
/dist/assets/**/*.png
/dist/assets/**/*.gif
/dist/assets/**/*.webp
